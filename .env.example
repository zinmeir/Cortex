# ─── LLM Provider ────────────────────────────────────────────────────────────
# Works with OpenAI, Together AI, Groq, Ollama (openai-compatible), etc.
OPENAI_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─── Memory Paths ─────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_store
EPISODIC_STORE_PATH=./data/episodic_store.json
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Agent Behaviour ─────────────────────────────────────────────────────────
MAX_ITERATIONS=10
MAX_RETRIES=3

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Web Search (optional) ───────────────────────────────────────────────────
# Get a free key at https://tavily.com  (recommended for agents)
TAVILY_API_KEY=

# Or use SerpAPI (https://serpapi.com)
SERPAPI_KEY=
